repeat task.wait() until game:IsLoaded()
local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer

-- Mengambil nama file dengan aman, mencegah error jika 'namaFile' kosong
local validNamaFile = getgenv().namaFile or "DefaultMacro"
local fileName = validNamaFile .. ".json"

local isRecording = false
local startTime = 0
local recordedActions = {}
local savedFileSuccess = false

getgenv().Metode = getgenv().Metode or "Instant"

local function resolveInstance(path)
    if not path or path == "" then return nil end
    local parts = string.split(path, ".")
    local current = game
    for _, part in ipairs(parts) do
        if part == "Workspace" then
            current = workspace
        else
            current = current:FindFirstChild(part)
        end
        if not current then return nil end
    end
    return current
end

local function serializeArgs(remoteName, args)
    local serialized = {}
    if remoteName == "PlaceTower" then
        local data = args[1]
        local instPath = data.instance and data.instance:GetFullName() or ""
        
        serialized[1] = {
            instancePath = instPath,
            position = {X = data.position.X, Y = data.position.Y, Z = data.position.Z},
            towerID = data.towerID,
            towerToPlace = data.towerToPlace
        }
    else
        for i, v in ipairs(args) do
            serialized[i] = v
        end
    end
    return serialized
end

local function deserializeArgs(remoteName, serialized)
    local args = {}
    if remoteName == "PlaceTower" then
        local data = serialized[1]
        args[1] = {
            instance = resolveInstance(data.instancePath),
            position = Vector3.new(data.position.X, data.position.Y, data.position.Z),
            towerID = data.towerID,
            towerToPlace = data.towerToPlace
        }
    else
        for i, v in ipairs(serialized) do
            args[i] = v
        end
    end
    return args
end

local function isActionValid(response)
    if response == nil or response == false then return false end
    
    if type(response) == "string" then
        local text = string.lower(response)
        if text == "" or string.find(text, "error") or string.find(text, "enough") or string.find(text, "limit") or string.find(text, "invalid") then
            return false
        end
    end
    
    if type(response) == "table" then
        if response.success == false or response.Success == false then
            return false
        end
    end
    
    return true
end

local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}

    if method == "InvokeServer" and isRecording then
        local name = self.Name
        if name == "PlaceTower" or name == "SellTower" or name == "UpgradeTower" then
            local actionTime = tick() - startTime
            
            local result = {oldNamecall(self, ...)}
            local serverResponse = result[1]

            if isActionValid(serverResponse) then
                task.spawn(function()
                    local success, err = pcall(function()
                        table.insert(recordedActions, {
                            Action = name,
                            Time = actionTime,
                            Args = serializeArgs(name, args)
                        })
                        print("[MENCATAT] " .. name .. " sukses, direkam!")
                    end)
                    if not success then
                        warn("[ERROR PENCATATAN] Gagal merekam: " .. tostring(err))
                    end
                end)
            end

            return unpack(result)
        end
    end

    return oldNamecall(self, ...)
end))

-- PERBAIKAN: Gunakan WaitForChild untuk menghindari error saat UI belum Load
local function getWaveUI()
    return LocalPlayer.PlayerGui:WaitForChild("UI"):WaitForChild("Game"):WaitForChild("Status"):WaitForChild("Info"):WaitForChild("Wave")
end

local function getGameUI()
    return LocalPlayer.PlayerGui:WaitForChild("UI"):WaitForChild("Game"):WaitForChild("GameOver")
end

local function getReadyUI()
    return LocalPlayer.PlayerGui:WaitForChild("UI"):WaitForChild("Ready")
end

local function getGamemodeUI()
    return LocalPlayer.PlayerGui:WaitForChild("UI"):WaitForChild("Game"):WaitForChild("Gamemodes")
end

getgenv().RecordMacro = function()
    task.spawn(function()
        local waveUI = getWaveUI()
        local gameOverUI = getGameUI()
        print("[SISTEM] Menunggu UI Wave muncul untuk mulai merekam...")
        
        while not waveUI.Visible do task.wait(0.1) end

        print("[SISTEM] Wave dimulai! Perekaman berjalan...")
        isRecording = true
        startTime = tick()
        recordedActions = {}

        while not gameOverUI.Visible do task.wait(0.1) end

        isRecording = false
        print("[SISTEM] Wave selesai! Menyimpan data ke " .. fileName)
        
        local jsonData = HttpService:JSONEncode(recordedActions)
        writefile(fileName, jsonData)
        print("[SISTEM] File berhasil disimpan!")
        savedFileSuccess = true
    end)
end

getgenv().PlayMacro = function()
    if not isfile(fileName) then 
        warn("[ERROR] File " .. fileName .. " tidak ditemukan! Silakan record dulu.")
        return 
    end

    task.spawn(function()
        local data = HttpService:JSONDecode(readfile(fileName))
        local waveUI = getWaveUI()
        
        print("[SISTEM] Menunggu UI Wave muncul untuk menjalankan macro...")
        
        while not waveUI.Visible do task.wait(0.1) end

        local mode = getgenv().Metode
        print("[SISTEM] Wave dimulai! Menjalankan macro dengan metode: " .. mode)
        local playStartTime = tick()

        for _, action in ipairs(data) do
            local remote = ReplicatedStorage.Remotes.Functions:WaitForChild(action.Action, 10)
            if remote then
                if mode == "Instant" then
                    local success = false
                    repeat
                        -- PERBAIKAN: Resolve argument di dalam loop agar terus mencoba saat Map lambat load
                        local args = deserializeArgs(action.Action, action.Args)
                        
                        -- Cek apakah instance map sudah termuat (khusus PlaceTower)
                        if action.Action == "PlaceTower" and args[1] and args[1].instance == nil then
                            task.wait(0.5) -- Tunggu map termuat
                        else
                            local callSuccess, result = pcall(function()
                                return remote:InvokeServer(unpack(args))
                            end)
                            
                            if callSuccess and isActionValid(result) then
                                success = true
                                print("[PLAYBACK INSTANT] " .. action.Action .. " Berhasil!")
                            else
                                task.wait(0.1)
                            end
                        end
                    until success
                else
                    -- METODE TIME
                    local targetTime = action.Time
                    local currentTime = tick() - playStartTime

                    if currentTime < targetTime then
                        task.wait(targetTime - currentTime)
                    end

                    task.spawn(function()
                        local success = false
                        repeat
                            -- PERBAIKAN: Sama, ditaruh di dalam loop untuk Time mode
                            local args = deserializeArgs(action.Action, action.Args)
                            
                            if action.Action == "PlaceTower" and args[1] and args[1].instance == nil then
                                task.wait(0.5) -- Tunggu map
                            else
                                local callSuccess, result = pcall(function()
                                    return remote:InvokeServer(unpack(args))
                                end)
                                
                                if callSuccess and isActionValid(result) then
                                    success = true
                                    print("[PLAYBACK TIME] " .. action.Action .. " Berhasil!")
                                else
                                    task.wait(0.1)
                                end
                            end
                        until success
                    end)
                end
            end
        end
        print("[SISTEM] Semua antrean macro telah selesai dijalankan.")
    end)
end

local validRunn = getgenv().Runn or ""
if validRunn == "PlayMacro" then
    PlayMacro()
elseif validRunn == "RecordMacro" then
    RecordMacro()
end

