    local gameUI = getGameUI()
    local readyUI = getReadyUI()
    local gamemodeUI = getGamemodeUI()

    while not readyUI.Visible do task.wait(0.1) end
    game:GetService("ReplicatedStorage").Remotes.Events.Ready:FireServer()
    
    while not gamemodeUI.Visible do task.wait(0.1) end
    local validGamemode = getgenv().Gamemode or "Normal" -- Cegah error jika Gamemode belum di-set
    game:GetService("ReplicatedStorage").Remotes.Events.Gamemode:FireServer(validGamemode)
    
    task.wait(0.5)
    game:GetService("ReplicatedStorage").Remotes.Events.InitChangeSpeed:FireServer(1)
    
    while not gameUI.Visible and not savedFileSuccess do task.wait(0.1) end
    
    -- Tunggu tombol Replay muncul sebelum diklik
    local replayBtn = LocalPlayer.PlayerGui:WaitForChild("UI"):WaitForChild("Game"):WaitForChild("GameOver"):WaitForChild("Buttons"):WaitForChild("Replay"):WaitForChild("Button")
    firesignal(replayBtn.Activated)
end)
